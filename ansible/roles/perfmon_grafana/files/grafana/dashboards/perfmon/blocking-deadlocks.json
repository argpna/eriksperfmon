          "rawQuery": true,
          "rawSql": "\nSELECT TOP (50)\n    d.event_date,\n    d.database_name,\n    d.deadlock_group,\n    d.deadlock_id\nFROM (\n    SELECT\n        event_date,\n        database_name,\n        deadlock_group,\n        deadlock_id,\n        rn = ROW_NUMBER() OVER (PARTITION BY deadlock_group ORDER BY deadlock_id)\n    FROM collect.deadlocks\n    WHERE collection_time >= DATEADD(MINUTE, DATEDIFF(MINUTE, GETUTCDATE(), GETDATE()), CONVERT(datetime2, $__timeFrom())) AND collection_time < DATEADD(MINUTE, DATEDIFF(MINUTE, GETUTCDATE(), GETDATE()), CONVERT(datetime2, $__timeTo()))\n) AS d\nWHERE d.rn = 1\nORDER BY d.event_date DESC;\n"
