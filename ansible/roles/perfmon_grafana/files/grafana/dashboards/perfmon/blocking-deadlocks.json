          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT time = DATEADD(MINUTE, DATEDIFF(MINUTE, GETDATE(), GETUTCDATE()), wt.collection_time), metric = wt.wait_type, value = SUM(CONVERT(float, wt.wait_duration_ms)) FROM collect.waiting_tasks AS wt WHERE wt.collection_time >= DATEADD(MINUTE, DATEDIFF(MINUTE, GETUTCDATE(), GETDATE()), CONVERT(datetime2, $__timeFrom())) AND wt.collection_time < DATEADD(MINUTE, DATEDIFF(MINUTE, GETUTCDATE(), GETDATE()), CONVERT(datetime2, $__timeTo())) AND wt.wait_type NOT IN (N'SLEEP', N'WAITFOR', N'BROKER_TO_FLUSH') GROUP BY wt.collection_time, wt.wait_type ORDER BY wt.collection_time;"
