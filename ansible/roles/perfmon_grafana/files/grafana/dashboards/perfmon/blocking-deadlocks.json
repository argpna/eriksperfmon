          "rawQuery": true,
          "rawSql": "\nSELECT TOP (100)\n    bca.collection_time,\n    bca.session_id,\n    bca.blocking_session_id,\n    bca.blocking_chain_position,\n    sessions_blocked = bca.sessions_blocked,\n    bca.wait_type,\n    wait_sec = CONVERT(decimal(19,2), bca.wait_duration_sec),\n    bca.database_name,\n    bca.command,\n    bca.cpu_time_ms,\n    bca.logical_reads,\n    bca.severity,\n    bca.recommendation,\n    query_text = LEFT(bca.query_text, 300)\nFROM report.blocking_chain_analysis AS bca\nWHERE bca.collection_time >= DATEADD(MINUTE, DATEDIFF(MINUTE, GETUTCDATE(), GETDATE()), CONVERT(datetime2, $__timeFrom())) AND bca.collection_time < DATEADD(MINUTE, DATEDIFF(MINUTE, GETUTCDATE(), GETDATE()), CONVERT(datetime2, $__timeTo()))\nORDER BY bca.collection_time DESC, bca.sessions_blocked DESC;\n"
