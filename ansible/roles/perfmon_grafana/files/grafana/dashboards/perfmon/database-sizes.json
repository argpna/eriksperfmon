  "editable": true,
  "graphTooltip": 1,
  "fiscalYearStartMonth": 0,
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "refresh": "15m",
  "weekStart": "",
  "annotations": {
    "list": []
  },
  "links": [
    {
      "title": "Fleet Overview",
      "icon": "dashboard",
      "type": "link",
      "url": "/d/perfmon-fleet?${__url_time_range}",
      "keepTime": true,
      "includeVars": false,
      "targetBlank": false
    },
    {
      "asDropdown": true,
