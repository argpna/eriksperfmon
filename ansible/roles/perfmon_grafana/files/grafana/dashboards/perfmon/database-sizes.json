    },
    {
      "asDropdown": true,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": [
        "perfmon"
      ],
      "targetBlank": false,
      "title": "All PerfMon Dashboards",
      "type": "dashboards",
      "url": ""
    }
  ],
  "templating": {
    "list": [
      {
        "name": "instance",
        "label": "Instance",
        "type": "datasource",
        "query": "mssql",
        "regex": "/^PerfMon-/",
        "current": {},
        "options": [],
        "refresh": 1,
        "hide": 0,
        "multi": false,
        "includeAll": false,
        "sort": 1,
        "description": "Monitored SQL Server instance - one MSSQL datasource per instance. Type to search."
      },
      {
        "name": "monthly_cost",
        "label": "Monthly Cost (USD)",
        "type": "textbox",
        "current": {
          "text": "0",
          "value": "0"
        },
        "options": [
          {
            "text": "0",
            "value": "0"
          }
        ],
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "Database Sizes",
      "datasource": {
        "type": "mssql",
        "uid": "${instance}"
      },
      "gridPos": {
        "h": 14,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "filterable": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "state_desc"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "ONLINE": {
                        "color": "green",
                        "index": 0
                      },
                      "RESTORING": {
                        "color": "orange",
                        "index": 1
                      },
                      "RECOVERING": {
                        "color": "orange",
                        "index": 2
                      },
                      "OFFLINE": {
                        "color": "red",
                        "index": 3
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "monthly_cost_share"
            },
            "properties": [
              {
                "id": "unit",
                "value": "currencyUSD"
              },
              {
                "id": "displayName",
                "value": "Monthly Cost Share"
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": [
            "sum"
          ],
          "fields": ""
        },
        "sortBy": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "mssql",
            "uid": "${instance}"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "\nSET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED;\n\nWITH\n    params AS\n    (\n        SELECT monthly_cost = ISNULL(TRY_CONVERT(decimal(12,2), NULLIF(N${monthly_cost:sqlstring}, N'')), 0)\n    )\nSELECT\n    dss.database_name,\n    file_type_desc = dss.file_type_desc,\n    file_name = dss.file_name,\n    total_size_mb = dss.total_size_mb,\n    used_size_mb = dss.used_size_mb,\n    free_space_mb = dss.free_space_mb,\n    used_pct = dss.used_pct,\n    volume_mount_point = dss.volume_mount_point,\n    volume_total_mb = dss.volume_total_mb,\n    volume_free_mb = dss.volume_free_mb,\n    auto_growth_display =\n        CASE\n            WHEN dss.is_percent_growth = 1\n            THEN CAST(dss.growth_pct AS varchar) + N'%'\n            WHEN dss.auto_growth_mb = 0\n            THEN N'Disabled'\n            ELSE CAST(CAST(dss.auto_growth_mb AS int) AS varchar) + N' MB'\n        END,\n    max_size_mb = dss.max_size_mb,\n    recovery_model_desc = dss.recovery_model_desc,\n    vlf_count =\n        CASE\n            WHEN dss.file_type_desc = N'LOG'\n            THEN ISNULL(CAST(dss.vlf_count AS varchar), N'-')\n            ELSE N'N/A'\n        END,\n    state_desc = dss.state_desc,\n    monthly_cost_share =\n        CASE\n            WHEN p.monthly_cost > 0\n            THEN CONVERT(decimal(12,2),\n                dss.total_size_mb / SUM(dss.total_size_mb) OVER () * p.monthly_cost)\n            ELSE NULL\n        END\nFROM collect.database_size_stats AS dss\nCROSS JOIN params AS p\nWHERE dss.collection_time =\n(\n    SELECT MAX(collection_time)\n    FROM collect.database_size_stats\n)\nORDER BY\n    dss.total_size_mb DESC\nOPTION(MAXDOP 1, RECOMPILE);\n"
        }
      ]
    }
  ]
}
