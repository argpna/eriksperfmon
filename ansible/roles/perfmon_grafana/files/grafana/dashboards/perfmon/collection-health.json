{
  "uid": "perfmon-collection",
  "title": "PerfMon · Collection Health",
  "tags": [
    "perfmon"
  ],
  "timezone": "",
  "schemaVersion": 39,
  "editable": true,
  "graphTooltip": 1,
  "fiscalYearStartMonth": 0,
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "refresh": "1m",
  "weekStart": "",
  "annotations": {
    "list": []
  },
  "links": [
    {
      "title": "Fleet Overview",
      "icon": "dashboard",
      "type": "link",
      "url": "/d/perfmon-fleet?${__url_time_range}",
      "keepTime": true,
      "includeVars": false,
      "targetBlank": false
    },
    {
      "asDropdown": true,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": [
        "perfmon"
      ],
      "targetBlank": false,
      "title": "All PerfMon Dashboards",
      "type": "dashboards",
      "url": ""
    },
    {
      "asDropdown": true,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": [
        "finops"
      ],
      "targetBlank": false,
      "title": "All FinOps Dashboards",
      "type": "dashboards",
      "url": ""
    }
  ],
  "templating": {
    "list": [
      {
        "name": "instance",
        "label": "Instance",
        "type": "datasource",
        "query": "mssql",
        "regex": "/^PerfMon-/",
        "current": {},
        "options": [],
        "refresh": 1,
        "hide": 0,
        "multi": false,
        "includeAll": false,
        "sort": 1,
        "description": "Monitored SQL Server instance - one MSSQL datasource per instance. Type to search."
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Collectors reporting",
      "datasource": {
        "type": "mssql",
        "uid": "${instance}"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "mssql",
            "uid": "${instance}"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT v = COUNT_BIG(DISTINCT cl.collector_name) FROM config.collection_log AS cl WHERE cl.collection_time >= DATEADD(DAY, -7, SYSDATETIME());"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Collectors unhealthy",
      "datasource": {
        "type": "mssql",
        "uid": "${instance}"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 3
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "mssql",
            "uid": "${instance}"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT v = COUNT_BIG(DISTINCT cl.collector_name) FROM config.collection_log AS cl WHERE cl.collection_time >= DATEADD(MINUTE, -5, SYSDATETIME()) AND cl.collection_status = N'ERROR';"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Collection age",
      "datasource": {
        "type": "mssql",
        "uid": "${instance}"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 15
              }
            ]
          },
          "unit": "m"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "mssql",
            "uid": "${instance}"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT v = DATEDIFF(MINUTE, MAX(cl.collection_time), SYSDATETIME()) FROM config.collection_log AS cl;"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Rows collected (range)",
      "datasource": {
        "type": "mssql",
        "uid": "${instance}"
      },
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "blue",
                "value": null
              }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "mssql",
            "uid": "${instance}"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT v = ISNULL(SUM(CONVERT(bigint, cl.rows_collected)), 0) FROM config.collection_log AS cl WHERE cl.collection_time >= DATEADD(MINUTE, DATEDIFF(MINUTE, GETUTCDATE(), GETDATE()), CONVERT(datetime2, $__timeFrom())) AND cl.collection_time < DATEADD(MINUTE, DATEDIFF(MINUTE, GETUTCDATE(), GETDATE()), CONVERT(datetime2, $__timeTo())) AND cl.collection_status = N'SUCCESS';"
        }
      ]
    },
    {
      "id": 5,
      "type": "table",
      "title": "Collector health (last 7 days)",
      "datasource": {
        "type": "mssql",
        "uid": "${instance}"
      },
      "gridPos": {
        "h": 11,
        "w": 24,
        "x": 0,
        "y": 4
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "filterable": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "health_status"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "HEALTHY": {
                        "color": "green",
                        "index": 0
                      },
                      "WARNING": {
                        "color": "yellow",
                        "index": 1
                      },
                      "FAILING": {
                        "color": "red",
                        "index": 2
                      },
                      "STALE": {
                        "color": "orange",
                        "index": 3
                      },
                      "NEVER_RUN": {
                        "color": "red",
                        "index": 4
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": [
            "sum"
          ],
          "fields": ""
        },
        "sortBy": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "mssql",
            "uid": "${instance}"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "\nSELECT\n    ch.collector_name,\n    ch.health_status,\n    ch.last_success_time,\n    ch.hours_since_success,\n    ch.failure_rate_percent,\n    ch.total_runs_7d,\n    ch.failed_runs_7d,\n    ch.avg_duration_ms,\n    ch.total_rows_collected_7d\nFROM report.collection_health AS ch\nORDER BY\n    CASE ch.health_status\n        WHEN N'FAILING' THEN 0\n        WHEN N'NEVER_RUN' THEN 1\n        WHEN N'STALE' THEN 2\n        WHEN N'WARNING' THEN 3\n        ELSE 4\n    END,\n    ch.collector_name;\n"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Collector duration (10 slowest)",
      "datasource": {
        "type": "mssql",
        "uid": "${instance}"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 15
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 12,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          },
          "unit": "ms"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "mssql",
            "uid": "${instance}"
          },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "\nSELECT\n    time = DATEADD(MINUTE, DATEDIFF(MINUTE, GETDATE(), GETUTCDATE()), cl.collection_time),\n    metric = cl.collector_name,\n    value = CONVERT(float, cl.duration_ms)\nFROM config.collection_log AS cl\nWHERE cl.collection_time >= DATEADD(MINUTE, DATEDIFF(MINUTE, GETUTCDATE(), GETDATE()), CONVERT(datetime2, $__timeFrom())) AND cl.collection_time < DATEADD(MINUTE, DATEDIFF(MINUTE, GETUTCDATE(), GETDATE()), CONVERT(datetime2, $__timeTo()))\n    AND cl.collection_status = N'SUCCESS'\n    AND cl.collector_name IN (\n        SELECT TOP (10)\n            c2.collector_name\n        FROM config.collection_log AS c2\n        WHERE c2.collection_time >= DATEADD(MINUTE, DATEDIFF(MINUTE, GETUTCDATE(), GETDATE()), CONVERT(datetime2, $__timeFrom())) AND c2.collection_time < DATEADD(MINUTE, DATEDIFF(MINUTE, GETUTCDATE(), GETDATE()), CONVERT(datetime2, $__timeTo()))\n            AND c2.collection_status = N'SUCCESS'\n        GROUP BY c2.collector_name\n        ORDER BY AVG(c2.duration_ms * 1.0) DESC\n    )\nORDER BY cl.collection_time;\n"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Rows collected (5m buckets)",
      "datasource": {
        "type": "mssql",
        "uid": "${instance}"
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 15
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "bars",
            "lineInterpolation": "smooth",
            "lineWidth": 1,
            "fillOpacity": 80,
            "showPoints": "never",
            "spanNulls": true,
            "stacking": {
              "mode": "none",
              "group": "A"
            }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true,
          "calcs": []
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "mssql",
            "uid": "${instance}"
          },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT time = DATEADD(MINUTE, DATEDIFF(MINUTE, 0, DATEADD(MINUTE, DATEDIFF(MINUTE, GETDATE(), GETUTCDATE()), cl.collection_time)) / 5 * 5, 0), total_rows = SUM(CONVERT(bigint, cl.rows_collected)) FROM config.collection_log AS cl WHERE cl.collection_time >= DATEADD(MINUTE, DATEDIFF(MINUTE, GETUTCDATE(), GETDATE()), CONVERT(datetime2, $__timeFrom())) AND cl.collection_time < DATEADD(MINUTE, DATEDIFF(MINUTE, GETUTCDATE(), GETDATE()), CONVERT(datetime2, $__timeTo())) AND cl.collection_status = N'SUCCESS' GROUP BY DATEADD(MINUTE, DATEDIFF(MINUTE, 0, DATEADD(MINUTE, DATEDIFF(MINUTE, GETDATE(), GETUTCDATE()), cl.collection_time)) / 5 * 5, 0) ORDER BY 1;"
        }
      ]
    },
    {
      "id": 8,
      "type": "table",
      "title": "Recent collector errors",
      "datasource": {
        "type": "mssql",
        "uid": "${instance}"
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 24
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "filterable": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": [
            "sum"
          ],
          "fields": ""
        },
        "sortBy": [
          {
            "displayName": "collection_time",
            "desc": true
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "mssql",
            "uid": "${instance}"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT TOP (100) cl.collection_time, cl.collector_name, cl.error_message FROM config.collection_log AS cl WHERE cl.collection_status = N'ERROR' AND cl.collection_time >= DATEADD(MINUTE, DATEDIFF(MINUTE, GETUTCDATE(), GETDATE()), CONVERT(datetime2, $__timeFrom())) AND cl.collection_time < DATEADD(MINUTE, DATEDIFF(MINUTE, GETUTCDATE(), GETDATE()), CONVERT(datetime2, $__timeTo())) ORDER BY cl.collection_time DESC;"
        }
      ]
    },
    {
      "id": 9,
      "type": "row",
      "title": "SQL Agent jobs",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 33
      },
      "panels": []
    },
    {
      "id": 10,
      "type": "table",
      "title": "Running SQL Agent jobs",
      "datasource": {
        "type": "mssql",
        "uid": "${instance}"
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 34
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "filterable": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "duration_status"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "LONG RUNNING": {
                        "color": "red",
                        "index": 0
                      },
                      "ABOVE AVERAGE": {
                        "color": "orange",
                        "index": 1
                      },
                      "NO HISTORY": {
                        "color": "yellow",
                        "index": 2
                      },
                      "NORMAL": {
                        "color": "green",
                        "index": 3
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": [
            "sum"
          ],
          "fields": ""
        },
        "sortBy": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "mssql",
            "uid": "${instance}"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "\nSELECT\n    rj.job_name,\n    rj.start_time,\n    current_duration = rj.current_duration_formatted,\n    avg_duration = rj.avg_duration_formatted,\n    p95_duration = rj.p95_duration_formatted,\n    rj.successful_run_count,\n    pct_of_avg = rj.percent_of_average,\n    rj.duration_status\nFROM report.running_jobs AS rj\nORDER BY\n    CASE rj.duration_status\n        WHEN N'LONG RUNNING' THEN 0\n        WHEN N'ABOVE AVERAGE' THEN 1\n        ELSE 3\n    END,\n    rj.current_duration_seconds DESC;\n"
        }
      ]
    }
  ]
}
