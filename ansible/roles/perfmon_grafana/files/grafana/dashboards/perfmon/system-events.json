      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "mssql",
            "uid": "${instance}"
          },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT time = DATEADD(MINUTE, DATEDIFF(MINUTE, GETDATE(), GETUTCDATE()), sh.collection_time), bad_pages_detected = CONVERT(float, sh.BadPagesDetected), bad_pages_fixed = CONVERT(float, sh.BadPagesFixed), interval_dump_requests = CONVERT(float, sh.intervalDumpRequests) FROM collect.HealthParser_SystemHealth AS sh WHERE sh.collection_time >= DATEADD(MINUTE, DATEDIFF(MINUTE, GETUTCDATE(), GETDATE()), CONVERT(datetime2, $__timeFrom())) AND sh.collection_time < DATEADD(MINUTE, DATEDIFF(MINUTE, GETUTCDATE(), GETDATE()), CONVERT(datetime2, $__timeTo())) ORDER BY sh.collection_time;"
