{
  "uid": "finops-index-usage",
  "title": "FinOps · Index Usage",
  "tags": [
    "finops"
  ],
  "timezone": "",
  "schemaVersion": 39,
  "editable": true,
  "graphTooltip": 1,
  "fiscalYearStartMonth": 0,
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "refresh": "15m",
  "weekStart": "",
  "annotations": {
    "list": []
  },
  "links": [
    {
      "title": "Fleet Overview",
      "icon": "dashboard",
      "type": "link",
      "url": "/d/perfmon-fleet?${__url_time_range}",
      "keepTime": true,
      "includeVars": false,
      "targetBlank": false
    },
    {
      "asDropdown": true,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": [
        "finops"
      ],
      "targetBlank": false,
      "title": "All FinOps Dashboards",
      "type": "dashboards",
      "url": ""
    },
    {
      "asDropdown": true,
      "icon": "external link",
      "includeVars": true,
      "keepTime": true,
      "tags": [
        "perfmon"
      ],
      "targetBlank": false,
      "title": "All PerfMon Dashboards",
      "type": "dashboards",
      "url": ""
    }
  ],
  "templating": {
    "list": [
      {
        "name": "instance",
        "label": "Instance",
        "type": "datasource",
        "query": "mssql",
        "regex": "/^PerfMon-/",
        "current": {},
        "options": [],
        "refresh": 1,
        "hide": 0,
        "multi": false,
        "includeAll": false,
        "sort": 1,
        "description": "Monitored SQL Server instance - one MSSQL datasource per instance. Type to search."
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "table",
      "title": "Index Usage",
      "datasource": {
        "type": "mssql",
        "uid": "${instance}"
      },
      "gridPos": {
        "h": 18,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "filterable": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "classification"
            },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "Unused": {
                        "color": "red",
                        "index": 0
                      },
                      "Write-only": {
                        "color": "orange",
                        "index": 1
                      },
                      "Active": {
                        "color": "green",
                        "index": 2
                      }
                    }
                  }
                ]
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "type": "color-background"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm",
        "footer": {
          "show": false,
          "reducer": [
            "sum"
          ],
          "fields": ""
        },
        "sortBy": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "mssql",
            "uid": "${instance}"
          },
          "format": "table",
          "rawQuery": true,
          "rawSql": "\nSET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED;\n\nSELECT TOP (200)\n    ios.database_name,\n    ios.schema_name,\n    ios.table_name,\n    index_name = ISNULL(ios.index_name, N'(heap)'),\n    classification =\n        CASE\n            WHEN ios.total_reads = 0 AND ISNULL(ios.user_updates, 0) = 0\n            THEN N'Unused'\n            WHEN ios.total_reads = 0 AND ISNULL(ios.user_updates, 0) > 0\n            THEN N'Write-only'\n            ELSE N'Active'\n        END,\n    ios.index_type_desc,\n    reserved_mb = ios.reserved_mb,\n    total_rows = ios.total_rows,\n    user_seeks = ISNULL(ios.user_seeks, 0),\n    user_scans = ISNULL(ios.user_scans, 0),\n    user_lookups = ISNULL(ios.user_lookups, 0),\n    total_reads = ios.total_reads,\n    user_updates = ISNULL(ios.user_updates, 0),\n    last_user_access =\n    (\n        SELECT MAX(v)\n        FROM (VALUES\n            (ios.last_user_seek),\n            (ios.last_user_scan),\n            (ios.last_user_lookup),\n            (ios.last_user_update)\n        ) AS x (v)\n    )\nFROM collect.index_object_stats AS ios\nWHERE ios.collection_time =\n(\n    SELECT MAX(collection_time)\n    FROM collect.index_object_stats\n)\nORDER BY\n    CASE WHEN ios.total_reads = 0 THEN 0 ELSE 1 END,\n    ios.reserved_mb DESC\nOPTION(MAXDOP 1, RECOMPILE);\n"
        }
      ],
      "description": "Unused / write-only indexes listed first"
    }
  ]
}
