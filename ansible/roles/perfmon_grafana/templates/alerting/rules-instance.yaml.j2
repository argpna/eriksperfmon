# Alert rules for {{ item.inventory_hostname }}
# Generated by Ansible perfmon_grafana role - do not edit directly.
# Source template: roles/perfmon_grafana/templates/alerting/rules-instance.yaml.j2
apiVersion: 1

groups:
  # -----------------------------------------------------------------------
  # High CPU
  # Upstream: AlertSeverity.HighCpu / UserPreferences.CpuThresholdPercent
  # Fires when the most recent CPU reading >= threshold.
  # Source: DatabaseService.NocHealth.cs GetCpuPercentAsync
  # -----------------------------------------------------------------------
  - orgId: 1
    name: "PerfMon - High CPU"
    folder: "{{ grafana_folder }}"
    interval: 1m
    rules:
      - uid: "perfmon-cpu-{{ item.inventory_hostname }}"
        title: "High CPU - {{ item.inventory_hostname }}"
        condition: C
        data:
          - refId: A
            relativeTimeRange:
              from: 300
              to: 0
            datasourceUid: "{{ perfmon_ds_uid_prefix }}-{{ item.inventory_hostname }}"
            model:
              datasource:
                type: mssql
                uid: "{{ perfmon_ds_uid_prefix }}-{{ item.inventory_hostname }}"
              format: table
              rawQuery: true
              rawSql: >
                SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED;
                SELECT TOP 1 COALESCE(total_cpu_utilization, sqlserver_cpu_utilization) AS cpu_pct
                FROM collect.cpu_utilization_stats
                ORDER BY collection_time DESC
                OPTION(MAXDOP 1, RECOMPILE)
              refId: A
          - refId: C
            datasourceUid: "-100"
            model:
              conditions:
                - evaluator:
                    params:
                      - {{ perfmon_alert_cpu_pct | float }}
                    type: gte
                  operator:
                    type: and
                  query:
                    params:
                      - A
                  reducer:
                    params: []
                    type: last
                  type: query
              datasource:
                type: __expr__
                uid: "-100"
              expression: A
              refId: C
              type: threshold
        noDataState: OK
        execErrState: Error
        for: 1m
        labels:
          team: perfmon
          instance: "{{ item.inventory_hostname }}"
        annotations:
          summary: >
            CPU utilization on {{ item.inventory_hostname }} exceeded {{ perfmon_alert_cpu_pct }}%.

  # -----------------------------------------------------------------------
  # Blocking Detected
  # Upstream: AlertSeverity.BlockingDetected / UserPreferences.BlockingThresholdSeconds
  # Fires when the longest current blocking wait >= threshold.
  # Source: DatabaseService.NocHealth.cs GetBlockingValuesAsync
  # -----------------------------------------------------------------------
  - orgId: 1
    name: "PerfMon - Blocking Detected"
    folder: "{{ grafana_folder }}"
    interval: 1m
    rules:
      - uid: "perfmon-blocking-{{ item.inventory_hostname }}"
        title: "Blocking Detected - {{ item.inventory_hostname }}"
        condition: C
        data:
          - refId: A
            relativeTimeRange:
              from: 300
              to: 0
            datasourceUid: "{{ perfmon_ds_uid_prefix }}-{{ item.inventory_hostname }}"
            model:
              datasource:
                type: mssql
                uid: "{{ perfmon_ds_uid_prefix }}-{{ item.inventory_hostname }}"
              format: table
              rawQuery: true
              rawSql: >
                SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED;
                SELECT ISNULL(MAX(s.waittime), 0) / 1000.0 AS longest_blocked_s
                FROM sys.sysprocesses AS s
                WHERE s.blocked <> 0 AND s.lastwaittype LIKE N'LCK%'
                OPTION(MAXDOP 1, RECOMPILE)
              refId: A
          - refId: C
            datasourceUid: "-100"
            model:
              conditions:
                - evaluator:
                    params:
                      - {{ perfmon_alert_blocking_s | float }}
                    type: gte
                  operator:
                    type: and
                  query:
                    params:
                      - A
                  reducer:
                    params: []
                    type: last
                  type: query
              datasource:
                type: __expr__
                uid: "-100"
              expression: A
              refId: C
              type: threshold
        noDataState: OK
        execErrState: Error
        for: 1m
        labels:
          team: perfmon
          instance: "{{ item.inventory_hostname }}"
        annotations:
          summary: >
            Blocking on {{ item.inventory_hostname }} has lasted at least {{ perfmon_alert_blocking_s }} seconds.

  # -----------------------------------------------------------------------
  # Deadlocks Detected
  # Upstream: AlertSeverity.DeadlocksDetected / UserPreferences.DeadlockThreshold
  # Fires when total deadlocks in the last 5 minutes >= threshold.
  # Source: DatabaseService.NocHealth.cs GetFilteredDeadlockCountAsync
  # -----------------------------------------------------------------------
  - orgId: 1
    name: "PerfMon - Deadlocks Detected"
    folder: "{{ grafana_folder }}"
    interval: 1m
    rules:
      - uid: "perfmon-deadlocks-{{ item.inventory_hostname }}"
        title: "Deadlocks Detected - {{ item.inventory_hostname }}"
        condition: C
        data:
          - refId: A
            relativeTimeRange:
              from: 300
              to: 0
            datasourceUid: "{{ perfmon_ds_uid_prefix }}-{{ item.inventory_hostname }}"
            model:
              datasource:
                type: mssql
                uid: "{{ perfmon_ds_uid_prefix }}-{{ item.inventory_hostname }}"
              format: table
              rawQuery: true
              rawSql: >
                SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED;
                SELECT COALESCE(SUM(deadlock_count_delta), 0) AS deadlock_count
                FROM collect.blocking_deadlock_stats
                WHERE collection_time >= DATEADD(minute, -5, SYSDATETIME())
                  AND deadlock_count_delta IS NOT NULL
                OPTION(MAXDOP 1, RECOMPILE)
              refId: A
          - refId: C
            datasourceUid: "-100"
            model:
              conditions:
                - evaluator:
                    params:
                      - {{ perfmon_alert_deadlock_count | int }}
                    type: gte
                  operator:
                    type: and
                  query:
                    params:
                      - A
                  reducer:
                    params: []
                    type: last
                  type: query
              datasource:
                type: __expr__
                uid: "-100"
              expression: A
              refId: C
              type: threshold
        noDataState: OK
        execErrState: Error
        for: 1m
        labels:
          team: perfmon
          instance: "{{ item.inventory_hostname }}"
        annotations:
          summary: >
            {{ perfmon_alert_deadlock_count }} or more deadlock(s) detected on {{ item.inventory_hostname }} in the last 5 minutes.

  # -----------------------------------------------------------------------
  # TempDB Space
  # Upstream: AlertSeverity.TempDbSpace / UserPreferences.TempDbThresholdPct
  # Fires when used pct of allocated TempDB space >= threshold.
  # Source: DatabaseService.NocHealth.cs GetTempDbSpaceAsync
  # Source table: collect.tempdb_stats
  # -----------------------------------------------------------------------
  - orgId: 1
    name: "PerfMon - TempDB Space"
    folder: "{{ grafana_folder }}"
    interval: 1m
    rules:
      - uid: "perfmon-tempdb-{{ item.inventory_hostname }}"
        title: "TempDB Space - {{ item.inventory_hostname }}"
        condition: C
        data:
          - refId: A
            relativeTimeRange:
              from: 300
              to: 0
            datasourceUid: "{{ perfmon_ds_uid_prefix }}-{{ item.inventory_hostname }}"
            model:
              datasource:
                type: mssql
                uid: "{{ perfmon_ds_uid_prefix }}-{{ item.inventory_hostname }}"
              format: table
              rawQuery: true
              rawSql: >
                SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED;
                SELECT TOP 1
                    CAST(total_reserved_mb AS float) * 100.0
                    / NULLIF(CAST(total_reserved_mb AS float) + CAST(unallocated_mb AS float), 0) AS tempdb_pct
                FROM collect.tempdb_stats
                ORDER BY collection_time DESC
                OPTION(MAXDOP 1)
              refId: A
          - refId: C
            datasourceUid: "-100"
            model:
              conditions:
                - evaluator:
                    params:
                      - {{ perfmon_alert_tempdb_pct | float }}
                    type: gte
                  operator:
                    type: and
                  query:
                    params:
                      - A
                  reducer:
                    params: []
                    type: last
                  type: query
              datasource:
                type: __expr__
                uid: "-100"
              expression: A
              refId: C
              type: threshold
        noDataState: OK
        execErrState: Error
        for: 5m
        labels:
          team: perfmon
          instance: "{{ item.inventory_hostname }}"
        annotations:
          summary: >
            TempDB on {{ item.inventory_hostname }} is {{ perfmon_alert_tempdb_pct }}% or more full.

  # -----------------------------------------------------------------------
  # Low Disk Space
  # Upstream: AlertSeverity.LowDisk / UserPreferences.DiskFreeThresholdPct + DiskFreeThresholdGb
  # Fires when any volume hosting a database file is below the free-space floor.
  # Source: DatabaseService.NocHealth.cs GetVolumeFreeSpaceAsync
  # Source table: collect.database_size_stats
  # -----------------------------------------------------------------------
  - orgId: 1
    name: "PerfMon - Low Disk Space"
    folder: "{{ grafana_folder }}"
    interval: 1m
    rules:
      - uid: "perfmon-disk-{{ item.inventory_hostname }}"
        title: "Low Disk Space - {{ item.inventory_hostname }}"
        condition: C
        data:
          - refId: A
            relativeTimeRange:
              from: 300
              to: 0
            datasourceUid: "{{ perfmon_ds_uid_prefix }}-{{ item.inventory_hostname }}"
            model:
              datasource:
                type: mssql
                uid: "{{ perfmon_ds_uid_prefix }}-{{ item.inventory_hostname }}"
              format: table
              rawQuery: true
              rawSql: >
                SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED;
                SELECT COUNT(*) AS disk_alert
                FROM (
                    SELECT MAX(volume_total_mb) AS total_mb, MIN(volume_free_mb) AS free_mb
                    FROM collect.database_size_stats
                    WHERE collection_time = (SELECT MAX(collection_time) FROM collect.database_size_stats)
                      AND volume_mount_point IS NOT NULL
                      AND volume_total_mb > 0
                    GROUP BY volume_mount_point
                ) v
                WHERE v.free_mb / 1024.0 < {{ perfmon_alert_disk_free_gb | float }}
                   OR v.free_mb * 100.0 / NULLIF(v.total_mb, 0) < {{ perfmon_alert_disk_free_pct | float }}
                OPTION(MAXDOP 1)
              refId: A
          - refId: C
            datasourceUid: "-100"
            model:
              conditions:
                - evaluator:
                    params:
                      - 1
                    type: gte
                  operator:
                    type: and
                  query:
                    params:
                      - A
                  reducer:
                    params: []
                    type: last
                  type: query
              datasource:
                type: __expr__
                uid: "-100"
              expression: A
              refId: C
              type: threshold
        noDataState: OK
        execErrState: Error
        for: 5m
        labels:
          team: perfmon
          instance: "{{ item.inventory_hostname }}"
        annotations:
          summary: >
            A volume on {{ item.inventory_hostname }} has less than {{ perfmon_alert_disk_free_pct }}% free
            or less than {{ perfmon_alert_disk_free_gb }} GB free.

  # -----------------------------------------------------------------------
  # Long-Running Query
  # Upstream: AlertSeverity.LongRunningQuery / UserPreferences.LongRunningQueryThreshold
  # Fires when any currently executing query has been running >= threshold minutes.
  # Source: DatabaseService.NocHealth.cs GetLongRunningQueriesAsync
  # -----------------------------------------------------------------------
  - orgId: 1
    name: "PerfMon - Long-Running Query"
    folder: "{{ grafana_folder }}"
    interval: 1m
    rules:
      - uid: "perfmon-long-query-{{ item.inventory_hostname }}"
        title: "Long-Running Query - {{ item.inventory_hostname }}"
        condition: C
        data:
          - refId: A
            relativeTimeRange:
              from: 300
              to: 0
            datasourceUid: "{{ perfmon_ds_uid_prefix }}-{{ item.inventory_hostname }}"
            model:
              datasource:
                type: mssql
                uid: "{{ perfmon_ds_uid_prefix }}-{{ item.inventory_hostname }}"
              format: table
              rawQuery: true
              rawSql: >
                SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED;
                SELECT COUNT(*) AS long_query_count
                FROM sys.dm_exec_requests AS r
                CROSS APPLY sys.dm_exec_sql_text(r.sql_handle) AS t
                JOIN sys.dm_exec_sessions AS s ON s.session_id = r.session_id
                WHERE r.session_id > 50
                  AND r.total_elapsed_time >= {{ perfmon_alert_query_duration_floor_min | float }} * 60000
                  AND r.wait_type NOT LIKE N'%SP_SERVER_DIAGNOSTICS%'
                  AND r.wait_type NOT IN (N'WAITFOR', N'BROKER_RECEIVE_WAITFOR')
                  AND r.wait_type NOT IN (N'BACKUPTHREAD', N'BACKUPIO')
                  AND r.wait_type NOT IN (N'XE_LIVE_TARGET_TVF')
                OPTION(MAXDOP 1, RECOMPILE)
              refId: A
          - refId: C
            datasourceUid: "-100"
            model:
              conditions:
                - evaluator:
                    params:
                      - 1
                    type: gte
                  operator:
                    type: and
                  query:
                    params:
                      - A
                  reducer:
                    params: []
                    type: last
                  type: query
              datasource:
                type: __expr__
                uid: "-100"
              expression: A
              refId: C
              type: threshold
        noDataState: OK
        execErrState: Error
        for: 1m
        labels:
          team: perfmon
          instance: "{{ item.inventory_hostname }}"
        annotations:
          summary: >
            A query on {{ item.inventory_hostname }} has been running for
            {{ perfmon_alert_query_duration_floor_min }} or more minutes.

  # -----------------------------------------------------------------------
  # Poison Wait
  # Upstream: AlertSeverity.PoisonWait / UserPreferences.PoisonWaitThresholdMs
  # Fires when avg ms per wait event for any of the three poison wait types exceeds
  # the threshold. Pure absolute check against the most recent rows in the last 10
  # minutes - no baseline comparison.
  # Source: DatabaseService.NocHealth.cs GetPoisonWaitDeltasAsync
  # Source table: collect.wait_stats (waiting_tasks_count_delta is a stored delta column)
  # -----------------------------------------------------------------------
  - orgId: 1
    name: "PerfMon - Poison Wait"
    folder: "{{ grafana_folder }}"
    interval: 1m
    rules:
      - uid: "perfmon-poison-wait-{{ item.inventory_hostname }}"
        title: "Poison Wait - {{ item.inventory_hostname }}"
        condition: C
        data:
          - refId: A
            relativeTimeRange:
              from: 600
              to: 0
            datasourceUid: "{{ perfmon_ds_uid_prefix }}-{{ item.inventory_hostname }}"
            model:
              datasource:
                type: mssql
                uid: "{{ perfmon_ds_uid_prefix }}-{{ item.inventory_hostname }}"
              format: table
              rawQuery: true
              rawSql: >
                SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED;
                SELECT COUNT(*) AS poison_wait_count
                FROM (
                    SELECT TOP 3
                        CASE WHEN waiting_tasks_count_delta > 0
                             THEN CAST(CAST(wait_time_ms_delta AS decimal(19,2)) / waiting_tasks_count_delta AS decimal(18,4))
                             ELSE 0 END AS avg_ms_per_wait
                    FROM collect.wait_stats
                    WHERE wait_type IN (N'THREADPOOL', N'RESOURCE_SEMAPHORE', N'RESOURCE_SEMAPHORE_QUERY_COMPILE')
                      AND waiting_tasks_count_delta > 0
                      AND collection_time >= DATEADD(minute, -10, SYSDATETIME())
                    ORDER BY collection_time DESC
                ) t
                WHERE avg_ms_per_wait >= {{ perfmon_alert_poison_wait_floor_ms | float }}
                OPTION(MAXDOP 1, RECOMPILE)
              refId: A
          - refId: C
            datasourceUid: "-100"
            model:
              conditions:
                - evaluator:
                    params:
                      - 1
                    type: gte
                  operator:
                    type: and
                  query:
                    params:
                      - A
                  reducer:
                    params: []
                    type: last
                  type: query
              datasource:
                type: __expr__
                uid: "-100"
              expression: A
              refId: C
              type: threshold
        noDataState: OK
        execErrState: Error
        for: 1m
        labels:
          team: perfmon
          instance: "{{ item.inventory_hostname }}"
        annotations:
          summary: >
            A poison wait type on {{ item.inventory_hostname }} has avg wait >= {{ perfmon_alert_poison_wait_floor_ms }}ms per event
            (THREADPOOL, RESOURCE_SEMAPHORE, or RESOURCE_SEMAPHORE_QUERY_COMPILE).

  # -----------------------------------------------------------------------
  # Long-Running Collector Job
  # Upstream: AlertSeverity.LongRunningJob / UserPreferences.LongRunningJobMultiplier
  # Fires when the PerformanceMonitor - Collection job's current duration exceeds a
  # multiple of its average. Scoped to the collector job only
  # Source: DatabaseService.NocHealth.cs GetAnomalousJobsAsync
  # Source table: collect.running_jobs
  # -----------------------------------------------------------------------
  - orgId: 1
    name: "PerfMon - Long-Running Collector Job"
    folder: "{{ grafana_folder }}"
    interval: 1m
    rules:
      - uid: "perfmon-long-job-{{ item.inventory_hostname }}"
        title: "Long-Running Collector Job - {{ item.inventory_hostname }}"
        condition: C
        data:
          - refId: A
            relativeTimeRange:
              from: 300
              to: 0
            datasourceUid: "{{ perfmon_ds_uid_prefix }}-{{ item.inventory_hostname }}"
            model:
              datasource:
                type: mssql
                uid: "{{ perfmon_ds_uid_prefix }}-{{ item.inventory_hostname }}"
              format: table
              rawQuery: true
              rawSql: >
                SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED;
                SELECT COUNT(*) AS long_job_count
                FROM collect.running_jobs
                WHERE collection_time = (SELECT MAX(collection_time) FROM collect.running_jobs)
                  AND job_name = N'PerformanceMonitor - Collection'
                  AND avg_duration_seconds >= 60
                  AND percent_of_average >= {{ (perfmon_alert_long_running_job_multiplier * 100) | int }}
                OPTION(MAXDOP 1, RECOMPILE)
              refId: A
          - refId: C
            datasourceUid: "-100"
            model:
              conditions:
                - evaluator:
                    params:
                      - 1
                    type: gte
                  operator:
                    type: and
                  query:
                    params:
                      - A
                  reducer:
                    params: []
                    type: last
                  type: query
              datasource:
                type: __expr__
                uid: "-100"
              expression: A
              refId: C
              type: threshold
        noDataState: OK
        execErrState: Error
        for: 1m
        labels:
          team: perfmon
          instance: "{{ item.inventory_hostname }}"
        annotations:
          summary: >
            The PerformanceMonitor - Collection job on {{ item.inventory_hostname }} has been running
            for {{ perfmon_alert_long_running_job_multiplier }}x or more its average duration.

  # -----------------------------------------------------------------------
  # Failed Collector Job
  # Upstream: NotifyOnFailedJobs / UserPreferences.FailedJobLookbackMinutes
  # Upstream monitors all SQL Agent jobs; we scope to PerformanceMonitor - Collection only.
  # Fires when the most recent overall run (step_id = 0) was a failure (run_status = 0).
  # Source: DatabaseService.NocHealth.cs GetRecentlyFailedJobsAsync
  # Access: msdb.dbo.sp_help_jobhistory (requires SQLAgentReaderRole)
  # -----------------------------------------------------------------------
  - orgId: 1
    name: "PerfMon - Failed Collector Job"
    folder: "{{ grafana_folder }}"
    interval: 1m
    rules:
      - uid: "perfmon-failed-job-{{ item.inventory_hostname }}"
        title: "Failed Collector Job - {{ item.inventory_hostname }}"
        condition: C
        data:
          - refId: A
            relativeTimeRange:
              from: 300
              to: 0
            datasourceUid: "{{ perfmon_ds_uid_prefix }}-{{ item.inventory_hostname }}"
            model:
              datasource:
                type: mssql
                uid: "{{ perfmon_ds_uid_prefix }}-{{ item.inventory_hostname }}"
              format: table
              rawQuery: true
              rawSql: |
                SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED;
                CREATE TABLE #jobhistory (
                    instance_id       BIGINT,
                    job_id            UNIQUEIDENTIFIER,
                    job_name          SYSNAME,
                    step_id           INT,
                    step_name         SYSNAME NULL,
                    sql_message_id    INT,
                    sql_severity      INT,
                    message           NVARCHAR(4000) NULL,
                    run_status        INT,
                    run_date          INT,
                    run_time          INT,
                    run_duration      INT,
                    operator_emailed  SYSNAME NULL,
                    operator_netsent  SYSNAME NULL,
                    operator_paged    SYSNAME NULL,
                    retries_attempted INT,
                    server            SYSNAME NULL
                );
                DECLARE @start_date int =
                    CONVERT(int, CONVERT(varchar(8), DATEADD(DAY, -1, GETDATE()), 112));
                INSERT INTO #jobhistory
                EXEC msdb.dbo.sp_help_jobhistory
                    @job_name       = N'PerformanceMonitor - Collection',
                    @start_run_date = @start_date,
                    @mode           = 'FULL';
                SELECT TOP 1
                    CASE WHEN run_status = 0 THEN 1 ELSE 0 END AS failed_collector_jobs
                FROM #jobhistory
                WHERE step_id = 0
                ORDER BY run_date DESC, run_time DESC OPTION(MAXDOP 1, RECOMPILE);
                DROP TABLE #jobhistory;
              refId: A
          - refId: C
            datasourceUid: "-100"
            model:
              conditions:
                - evaluator:
                    params:
                      - 1
                    type: gte
                  operator:
                    type: and
                  query:
                    params:
                      - A
                  reducer:
                    params: []
                    type: last
                  type: query
              datasource:
                type: __expr__
                uid: "-100"
              expression: A
              refId: C
              type: threshold
        noDataState: OK
        execErrState: Error
        for: 1m
        labels:
          team: perfmon
          instance: "{{ item.inventory_hostname }}"
        annotations:
          summary: >
            The PerformanceMonitor - Collection job on {{ item.inventory_hostname }} has failed
            within the last {{ perfmon_alert_failed_job_lookback_min }} minutes.

  # -----------------------------------------------------------------------
  # Collection Stopped
  # Upstream: GetCollectionStoppedAsync / DecideCollectionStopped
  # Fires when the PerformanceMonitor collector Agent job(s) are disabled, or when no
  # collector has logged a run within the freshness window. Disabled jobs win over the
  # freshness check.
  # Source: DatabaseService.NocHealth.cs GetCollectionStoppedAsync
  # Access: msdb.dbo.sysjobs_view (requires SQLAgentReaderRole, same grant as Failed Collector Job)
  # -----------------------------------------------------------------------
  - orgId: 1
    name: "PerfMon - Collection Stopped"
    folder: "{{ grafana_folder }}"
    interval: 1m
    rules:
      - uid: "perfmon-collection-stopped-{{ item.inventory_hostname }}"
        title: "Collection Stopped - {{ item.inventory_hostname }}"
        condition: C
        data:
          - refId: A
            relativeTimeRange:
              from: 300
              to: 0
            datasourceUid: "{{ perfmon_ds_uid_prefix }}-{{ item.inventory_hostname }}"
            model:
              datasource:
                type: mssql
                uid: "{{ perfmon_ds_uid_prefix }}-{{ item.inventory_hostname }}"
              format: table
              rawQuery: true
              rawSql: |
                SET TRANSACTION ISOLATION LEVEL READ UNCOMMITTED;
                DECLARE @total_jobs int = 0;
                DECLARE @disabled_jobs int = 0;
                DECLARE @minutes_since int;
                BEGIN TRY
                    /* SQLAgentReaderRole grants SELECT on sysjobs_view, not the sysjobs base
                       table (VIEW DEFINITION only there) */
                    SELECT
                        @total_jobs = COUNT_BIG(*),
                        @disabled_jobs = SUM(CASE WHEN sj.enabled = 0 THEN 1 ELSE 0 END)
                    FROM msdb.dbo.sysjobs_view AS sj
                    WHERE sj.name LIKE N'PerformanceMonitor%'
                    OPTION(RECOMPILE);
                END TRY
                BEGIN CATCH
                    /* Restricted msdb (e.g. AWS RDS) or no SQLAgentReaderRole - fall through to
                       the freshness check rather than falsely reporting jobs disabled. */
                    SET @total_jobs = 0;
                    SET @disabled_jobs = 0;
                END CATCH;
                SELECT @minutes_since = DATEDIFF(MINUTE, MAX(collection_time), SYSDATETIME())
                FROM config.collection_log
                OPTION(RECOMPILE);
                SELECT
                    collection_stopped =
                        CASE
                            WHEN @total_jobs > 0 AND @disabled_jobs > 0 THEN 1
                            WHEN @minutes_since >= {{ perfmon_alert_collection_stale_min | int }} THEN 1
                            ELSE 0
                        END;
              refId: A
          - refId: C
            datasourceUid: "-100"
            model:
              conditions:
                - evaluator:
                    params:
                      - 1
                    type: gte
                  operator:
                    type: and
                  query:
                    params:
                      - A
                  reducer:
                    params: []
                    type: last
                  type: query
              datasource:
                type: __expr__
                uid: "-100"
              expression: A
              refId: C
              type: threshold
        noDataState: OK
        execErrState: Error
        for: 1m
        labels:
          team: perfmon
          instance: "{{ item.inventory_hostname }}"
        annotations:
          summary: >
            Data collection on {{ item.inventory_hostname }} appears to have stopped: either the
            PerformanceMonitor collector Agent job(s) are disabled, or no collector has logged a
            run within the last {{ perfmon_alert_collection_stale_min }} minutes.
