# Note: Sensitive values are not defined within the Ansible roles.
# The roles consume these variables from `group_vars` only. For production
# deployments, store sensitive variables in an Ansible Vault and reference
# them from `group_vars` to maintain a stronger security posture.

# COMPOSE_PROFILES=ad
MSSQL_SA_PASSWORD=NotaStrongPass@1
MSSQL_READER_PASSWORD=NotaStrongPass@1
GRAFANA_ADMIN_PASSWORD=GrafanaAdmin1
# populated by bootstrap/setup-grafana-api-key.sh
GRAFANA_API_KEY=

SAMBA_ADMIN_PASSWORD=NotaStrongPass@1
AD_SQLADMIN_PASSWORD=NotaStrongPass@1
AD_READER_PASSWORD=NotaStrongPass@1
AD_SVC_MSSQL_PASSWORD=NotaStrongPass@1

AD_DOMAIN=lab.internal
AD_REALM=LAB.INTERNAL
AD_NETBIOS=LAB